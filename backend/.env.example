# ─── SERVER ──────────────────────────────────────────────────
# Render sets PORT automatically — do NOT set it here
FRONTEND_URL=https://your-app.onrender.com

# ─── OPENAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ─── PERPLEXITY ──────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
PERPLEXITY_MODEL=sonar-pro

# ─── WORDPRESS ───────────────────────────────────────────────
WORDPRESS_URL=https://yoursite.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=AbCd EfGh IjKl MnOp QrSt UvWx

# ─── CONTENT SETTINGS ────────────────────────────────────────
CONTENT_LANGUAGE=de
MIN_WORD_COUNT=1500
WP_POST_STATUS=draft
DEFAULT_CATEGORY_ID=1

# ─── SLACK (optional) ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── GOOGLE SEARCH CONSOLE (optional) ───────────────────────
# Render has no persistent filesystem — paste full JSON here
GSC_CREDENTIALS_JSON={"type":"service_account",...}
GSC_SITE_URL=sc-domain:yoursite.com
