# ─── SERVER ──────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://yourdomain.de

# ─── OPENAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ─── PERPLEXITY ──────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
PERPLEXITY_MODEL=sonar-pro

# ─── WORDPRESS ───────────────────────────────────────────────
WORDPRESS_URL=https://yoursite.de
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=AbCd EfGh IjKl MnOp QrSt UvWx

# ─── CONTENT SETTINGS ────────────────────────────────────────
CONTENT_LANGUAGE=de
MIN_WORD_COUNT=1500
WP_POST_STATUS=draft
DEFAULT_CATEGORY_ID=1

# ─── SLACK (optional) ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── GOOGLE SEARCH CONSOLE (optional) ───────────────────────
GSC_CREDENTIALS_PATH=/home/seoagent/seo-agent/gsc-service-account.json
GSC_SITE_URL=sc-domain:yoursite.de

# ─── NEW RELIC (one.newrelic.com — US) ───────────────────────
# 1. Go to one.newrelic.com
# 2. Click your name (bottom left) → API Keys
# 3. Create a key → type: INGEST - LICENSE
# 4. Paste the 40-character key below
NEW_RELIC_LICENSE_KEY=your-40-character-license-key-here
NEW_RELIC_APP_NAME=SEO Content Optimizer
