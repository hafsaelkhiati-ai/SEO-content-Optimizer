# ============================================================
# GEO CONTENT AGENT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it's in .gitignore by default.
# ============================================================

# ─── SERVER ─────────────────────────────────────────────────
PORT=3000
# Allowed origins for CORS (your frontend URL)
FRONTEND_URL=http://localhost:8080

# ─── OPENAI ─────────────────────────────────────────────────
# 🔑 Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ─── PERPLEXITY ─────────────────────────────────────────────
# 🔑 Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar-pro

# ─── WORDPRESS ──────────────────────────────────────────────
# 🔑 Your WP site URL (no trailing slash)
WORDPRESS_URL=https://yoursite.de
# 🔑 Your WP admin username
WORDPRESS_USERNAME=admin
# 🔑 Application password: WP Admin → Users → Profile → Application Passwords
# Generate one and paste it here (spaces are fine)
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── SLACK (OPTIONAL) ────────────────────────────────────────
# 🔑 Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# ─── GOOGLE SEARCH CONSOLE (OPTIONAL) ──────────────────────
# 🔑 Service account JSON path (absolute path on server)
GSC_CREDENTIALS_PATH=/home/ubuntu/seo-agent/gsc-service-account.json
# 🔑 Your GSC property (use sc-domain: prefix for domain properties)
GSC_SITE_URL=sc-domain:yoursite.de

# ─── CONTENT DEFAULTS ───────────────────────────────────────
CONTENT_LANGUAGE=de
MIN_WORD_COUNT=1500
# draft | publish
WP_POST_STATUS=draft
DEFAULT_CATEGORY_ID=1

# ─── SECURITY ────────────────────────────────────────────────
# Optional: set a secret to protect the API (send as X-API-Key header)
# Leave empty to disable auth (fine for local / VPS behind Nginx auth)
API_SECRET=
